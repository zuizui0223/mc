    rotation_range=20,
    width_shift_range=0.2,
    height_shift_range=0.2,
    shear_range=0.2,
    zoom_range=0.2,
    horizontal_flip=True,
    fill_mode='nearest' # 変換で空白ができた場合の埋め方
)

# 訓練データにデータ拡張を適用するためのジェネレータを作成
